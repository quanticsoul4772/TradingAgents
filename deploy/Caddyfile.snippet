# TradingAgents dashboard — Caddyfile snippet
#
# ADD these two `handle` blocks INSIDE the existing `rawcell.duckdns.org { ... }`
# site block in /etc/caddy/Caddyfile. Pattern matches the existing `handle /v2/`
# block on the VPS (SSH-verified against the actual Caddyfile 2026-05-10).
#
# Per spec 250 FR-029: extend the existing Caddyfile, do NOT create a new one.
# Per FR-030: TLS reuses the existing Let's Encrypt cert for rawcell.duckdns.org.
# Per FR-031: basic_auth reuses the existing `rawcell` user (same bcrypt hash
# used for /v2/).
# Per FR-032: path-routed at /trading/ — no new DNS record needed.
#
# After editing the host Caddyfile, reload Caddy:
#   sudo systemctl reload caddy
# (Caddy is host-installed on this VPS, not containerized — verified.)
#
# Verification:
#   curl -u rawcell:<password> https://rawcell.duckdns.org/trading/

# --- snippet to merge into the rawcell.duckdns.org { ... } site block ---

# Trading dashboard: same pattern as /v2/ (basic_auth + strip prefix + reverse proxy)
handle /trading/ {
    basic_auth {
        # SAME bcrypt hash as the existing rawcell user under /v2/
        # (verified against /etc/caddy/Caddyfile rawcell.duckdns.org block).
        rawcell $2a$14$LR33n8zvDaYNjmHwOtAWF.0eHbt1J7eP62QhZNXEaHcYX0nmGB3Sq
    }
    uri strip_prefix /trading
    reverse_proxy localhost:8000
}
handle /trading/* {
    # API + asset paths — strip prefix, no auth (browser remembers it from /trading/).
    # Per FR-010, /trigger/* is NOT proxied by Caddy (engine binds 127.0.0.1 only;
    # if a request hits /trading/trigger/* the strip_prefix sends /trigger/* to the
    # dashboard, which returns 404 on the public listener per FR-010).
    uri strip_prefix /trading
    reverse_proxy localhost:8000
}
